<%= form_with model: game, id: "game_form", class: "space-y-4" do |f| %>
<% end %>

<div class="space-y-4">
  <% if game.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-4 text-red-700">
      <ul class="list-disc list-inside">
        <% game.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= label_tag :name, "Name", class: "block text-sm font-medium text-gray-700" %>
    <%= text_field_tag "game[name]", game.name, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= label_tag :min_players, "Min Players", class: "block text-sm font-medium text-gray-700" %>
      <%= number_field_tag "game[min_players]", game.min_players, min: 1, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
    <div>
      <%= label_tag :max_players, "Max Players", class: "block text-sm font-medium text-gray-700" %>
      <%= number_field_tag "game[max_players]", game.max_players, min: 1, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= label_tag :min_playtime, "Min Playtime (min)", class: "block text-sm font-medium text-gray-700" %>
      <%= number_field_tag "game[min_playtime]", game.min_playtime, min: 1, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
    <div>
      <%= label_tag :max_playtime, "Max Playtime (min)", class: "block text-sm font-medium text-gray-700" %>
      <%= number_field_tag "game[max_playtime]", game.max_playtime, min: 1, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
  </div>

  <div>
    <%= label_tag :description, "Description", class: "block text-sm font-medium text-gray-700" %>
    <%= text_area_tag "game[description]", game.description, rows: 3, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= label_tag :condition, "Condition", class: "block text-sm font-medium text-gray-700" %>
      <%= select_tag "game[condition]", options_for_select([["— select —", ""]] + condition_options, game.condition), form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
    <div>
      <%= label_tag :bgg_url, "BGG URL", class: "block text-sm font-medium text-gray-700" %>
      <%= url_field_tag "game[bgg_url]", game.bgg_url, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
  </div>

  <div>
    <%= label_tag :genre_ids, "Genres", class: "block text-sm font-medium text-gray-700" %>
    <div id="genre_form_list" class="mt-1 grid grid-cols-2 gap-2 sm:grid-cols-3">
      <% @genres.each do |genre| %>
        <label class="flex items-center gap-2 text-sm text-gray-700" id="game_genre_label_<%= genre.id %>">
          <%= check_box_tag "game[genre_ids][]", genre.id, game.genres.include?(genre), id: "game_genre_#{genre.id}", form: "game_form" %>
          <%= genre.name %>
        </label>
      <% end %>
    </div>
    <%= form_with url: genres_path, class: "mt-2" do %>
      <input type="hidden" name="context" value="game_form">
      <div class="flex gap-1">
        <%= text_field_tag "genre[name]", nil, placeholder: "New genre", id: "genre_form_add_input", class: "flex-1 border-gray-300 rounded text-sm px-2 py-1" %>
        <%= submit_tag "Add", class: "bg-indigo-600 text-white px-2 py-1 rounded text-sm hover:bg-indigo-700 cursor-pointer" %>
      </div>
      <div id="genre_form_error"></div>
    <% end %>
  </div>

  <div class="grid grid-cols-3 gap-4">
    <div>
      <%= label_tag :complexity, "Complexity (1–5)", class: "block text-sm font-medium text-gray-700" %>
      <%= number_field_tag "game[complexity]", game.complexity, min: 1, max: 5, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
    <div>
      <%= label_tag :enjoyment, "Enjoyment (1–5)", class: "block text-sm font-medium text-gray-700" %>
      <%= number_field_tag "game[enjoyment]", game.enjoyment, min: 1, max: 5, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
    <div>
      <%= label_tag :times_played, "Times Played", class: "block text-sm font-medium text-gray-700" %>
      <%= number_field_tag "game[times_played]", game.times_played, min: 0, form: "game_form", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= submit_tag (game.persisted? ? "Update Game" : "Create Game"), form: "game_form", class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", games_path, class: "px-4 py-2 text-gray-600 hover:underline" %>
  </div>
</div>
