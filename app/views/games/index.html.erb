<% content_for :title, "Games" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">My Games</h1>
  <%= link_to "Add Game", new_game_path, class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
</div>

<div class="flex gap-6 items-start">
  <%# Filter panel %>
  <div class="w-64 shrink-0 bg-white border border-gray-200 rounded-lg p-4 space-y-5 shadow-sm">

    <div>
      <p class="text-sm font-semibold text-gray-700 mb-2">Genres</p>
      <div class="flex gap-3 mb-2 text-sm">
        <%= form_with url: games_path, method: :get, id: "filter_form" do %>
          <input type="hidden" name="sort" value="<%= @filter_params[:sort] %>">
          <input type="hidden" name="direction" value="<%= @filter_params[:direction] %>">
        <% end %>
        <label class="flex items-center gap-1">
          <%= radio_button_tag :genre_mode, "or", @filter_params[:genre_mode] != "and", class: "accent-indigo-600", form: "filter_form" %>
          OR
        </label>
        <label class="flex items-center gap-1">
          <%= radio_button_tag :genre_mode, "and", @filter_params[:genre_mode] == "and", class: "accent-indigo-600", form: "filter_form" %>
          AND
        </label>
      </div>
      <div id="genre_filter_list" class="space-y-1 max-h-48 overflow-y-auto">
        <% @genres.each do |genre| %>
          <div class="flex items-center justify-between gap-1 text-sm text-gray-700" id="filter_genre_<%= genre.id %>">
            <label class="flex items-center gap-2">
              <%= check_box_tag "genre_ids[]", genre.id, Array(@filter_params[:genre_ids]).map(&:to_s).include?(genre.id.to_s), id: "filter_genre_checkbox_#{genre.id}", form: "filter_form" %>
              <%= genre.name %>
            </label>
            <%= button_to "×", genre_path(genre), method: :delete, class: "w-5 h-5 flex items-center justify-center rounded text-gray-400 hover:bg-red-100 hover:text-red-600 bg-transparent border-0 cursor-pointer text-base leading-none font-medium", data: { turbo_confirm: "Delete #{genre.name}? This will remove it from all games." }, aria: { label: "Delete #{genre.name}" } %>
          </div>
        <% end %>
      </div>
      <%= form_with url: genres_path, class: "mt-2" do %>
        <div class="flex gap-1">
          <%= text_field_tag "genre[name]", nil, placeholder: "New genre", id: "genre_add_input", class: "flex-1 border-gray-300 rounded text-sm px-2 py-1" %>
          <%= submit_tag "Add", class: "bg-indigo-600 text-white px-2 py-1 rounded text-sm hover:bg-indigo-700 cursor-pointer" %>
        </div>
        <div id="genre_error"></div>
      <% end %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Condition</label>
      <%= select_tag :condition,
            options_for_select([["Any", ""]] + condition_options, @filter_params[:condition]),
            class: "w-full border-gray-300 rounded text-sm", form: "filter_form" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Players</label>
      <%= number_field_tag :player_count, @filter_params[:player_count], min: 1, placeholder: "e.g. 4", class: "w-full border-gray-300 rounded text-sm", form: "filter_form" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Max playtime (min)</label>
      <%= number_field_tag :max_playtime, @filter_params[:max_playtime], min: 1, placeholder: "e.g. 60", class: "w-full border-gray-300 rounded text-sm", form: "filter_form" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Complexity</label>
      <%= select_tag :complexity,
            options_for_select([["Any", ""]] + (1..5).map { |n| [n, n] }, @filter_params[:complexity]),
            class: "w-full border-gray-300 rounded text-sm", form: "filter_form" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-1">Enjoyment</label>
      <%= select_tag :enjoyment,
            options_for_select([["Any", ""]] + (1..5).map { |n| [n, n] }, @filter_params[:enjoyment]),
            class: "w-full border-gray-300 rounded text-sm", form: "filter_form" %>
    </div>

    <div class="flex gap-2">
      <%= submit_tag "Filter", class: "flex-1 bg-indigo-600 text-white px-3 py-2 rounded text-sm hover:bg-indigo-700 cursor-pointer", form: "filter_form" %>
      <%= link_to "Clear", games_path, class: "flex-1 text-center border border-gray-300 text-gray-600 px-3 py-2 rounded text-sm hover:bg-gray-50" %>
    </div>
  </div>

  <%# Games table %>
  <div class="flex-1 overflow-x-auto">
    <% if @games.any? %>
      <table class="min-w-full bg-white border border-gray-200 rounded-lg shadow-sm">
        <thead class="bg-gray-50">
          <tr>
            <% sortable_columns = { "Name" => "name", "Complexity" => "complexity", "Enjoyment" => "enjoyment", "Played" => "times_played" } %>
            <% non_sortable = ["Genres", "Players", "Playtime", "Condition", "BGG", ""] %>

            <% sortable_columns.each do |label, col| %>
              <%
                current_sort = @filter_params[:sort].presence || "name"
                current_dir  = @filter_params[:direction].presence || "asc"
                next_dir     = (current_sort == col && current_dir == "asc") ? "desc" : "asc"
                arrow        = current_sort == col ? (current_dir == "asc" ? " ▲" : " ▼") : ""
              %>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">
                <%= link_to "#{label}#{arrow}", games_path(@filter_params.except(:sort, :direction).merge(sort: col, direction: next_dir)), class: "hover:text-indigo-600" %>
              </th>
            <% end %>

            <% non_sortable.each do |label| %>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700"><%= label %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @games.each do |game| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900">
                <%= game.name %>
                <% if game.base_game %>
                  <div class="text-xs text-gray-400 font-normal">Expansion of <%= game.base_game.name %></div>
                <% end %>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= game.complexity %></td>
              <td class="px-4 py-3 text-gray-600"><%= game.enjoyment %></td>
              <td class="px-4 py-3 text-gray-600"><%= game.times_played %></td>
              <td class="px-4 py-3 text-gray-600"><%= game.genres.map(&:name).join(", ") %></td>
              <td class="px-4 py-3 text-gray-600"><%= player_range(game.min_players, game.max_players) %></td>
              <td class="px-4 py-3 text-gray-600"><%= playtime_range(game.min_playtime, game.max_playtime) %></td>
              <td class="px-4 py-3 text-gray-600"><%= game.condition&.humanize %></td>
              <td class="px-4 py-3">
                <% if game.bgg_url.present? %>
                  <%= link_to "BGG", game.bgg_url, target: "_blank", rel: "noopener", class: "text-indigo-600 hover:underline" %>
                <% end %>
              </td>
              <td class="px-4 py-3 flex gap-3 text-sm">
                <%= link_to "Edit", edit_game_path(game), class: "text-indigo-600 hover:underline" %>
                <%= button_to "Delete", game_path(game), method: :delete, class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer", data: { turbo_confirm: "Delete #{game.name}?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-gray-500">No games match your filters. <%= link_to "Clear filters", games_path, class: "text-indigo-600 hover:underline" %></p>
    <% end %>
  </div>
</div>
