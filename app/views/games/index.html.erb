<% content_for :title, "Games" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">My Games</h1>
  <%= link_to "Add Game", new_game_path, class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
</div>

<% if @games.any? %>
  <div class="overflow-x-auto">
    <table class="min-w-full bg-white border border-gray-200 rounded-lg shadow-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Name</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Players</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Playtime</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Condition</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Complexity</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Enjoyment</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">Played</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-700">BGG</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @games.each do |game| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-900"><%= game.name %></td>
            <td class="px-4 py-3 text-gray-600"><%= [game.min_players, game.max_players].compact.join("–") %></td>
            <td class="px-4 py-3 text-gray-600"><%= [game.min_playtime, game.max_playtime].compact.join("–").then { |s| s.present? ? "#{s} min" : "" } %></td>
            <td class="px-4 py-3 text-gray-600"><%= game.condition&.humanize %></td>
            <td class="px-4 py-3 text-gray-600"><%= game.complexity %></td>
            <td class="px-4 py-3 text-gray-600"><%= game.enjoyment %></td>
            <td class="px-4 py-3 text-gray-600"><%= game.times_played %></td>
            <td class="px-4 py-3">
              <% if game.bgg_url.present? %>
                <%= link_to "BGG", game.bgg_url, target: "_blank", rel: "noopener", class: "text-indigo-600 hover:underline" %>
              <% end %>
            </td>
            <td class="px-4 py-3 flex gap-3 text-sm">
              <%= link_to "Edit", edit_game_path(game), class: "text-indigo-600 hover:underline" %>
              <%= button_to "Delete", game_path(game), method: :delete, class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer", data: { turbo_confirm: "Delete #{game.name}?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-gray-500">No games yet. <%= link_to "Add one!", new_game_path, class: "text-indigo-600 hover:underline" %></p>
<% end %>
